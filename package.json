{
  "name": "epi-city",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "run-simulation": "node scripts/simulation/run-simulation.mjs --script ./scripts/render/epi-city-video.example.json --output ./tmp/epi-city-recording.json",
    "generate-headless-world": "node scripts/simulation/generate-headless-world.mjs --config ./scripts/simulation/headless-world-config.example.json --output ./scripts/simulation/epi-city-world.json",
    "run-headless-simulation": "node scripts/simulation/run-headless-simulation.mjs --config ./scripts/simulation/headless-run-config.example.json --world ./scripts/simulation/epi-city-world.json --output ./tmp/epi-city-results.json",
    "render:video": "node scripts/render/render-epi-video.mjs --script ./scripts/render/epi-city-video.example.json --output ./tmp/epi-city-video.mp4 --fps 30 --width 1920 --height 1080",
    "check": "npm run test && npm run build && node --check map-editor/server.mjs && node --check map-editor/setup-python-env.mjs && node --check simulation-explorer/server.mjs && PYTHONDONTWRITEBYTECODE=1 python3 -m py_compile map-editor/train_random_forest.py process_gta_map/build-gta-tilemap.py",
    "map-editor": "node map-editor/server.mjs",
    "map-editor:deps": "node map-editor/setup-python-env.mjs",
    "simulation-explorer": "node simulation-explorer/server.mjs"
  },
  "devDependencies": {
    "ffmpeg-static": "^5.3.0",
    "playwright-core": "^1.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "pixi.js": "^8.18.1",
    "three": "^0.184.0"
  }
}
